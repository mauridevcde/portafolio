          { '@type': 'ListItem', position: 1, name: 'Inicio', item: 'https://mauriciogonzalez.dev/#home' },
          { '@type': 'ListItem', position: 2, name: 'Sobre Mí', item: 'https://mauriciogonzalez.dev/#about' },
          { '@type': 'ListItem', position: 3, name: 'Proyectos', item: 'https://mauriciogonzalez.dev/#projects' },
          { '@type': 'ListItem', position: 4, name: 'Servicios', item: 'https://mauriciogonzalez.dev/#services' },
          { '@type': 'ListItem', position: 5, name: 'Blog', item: 'https://mauriciogonzalez.dev/blog/' },
          { '@type': 'ListItem', position: 6, name: 'Contacto', item: 'https://mauriciogonzalez.dev/#contact' },
        ],
      },
    ],
  },
]);
---

<BaseLayout
  title="Mauricio González | Desarrollador Full Stack Remoto — React · NestJS · TypeScript"
  description="Desarrollador Full Stack con 5+ años de experiencia. Disponible para trabajo remoto en Latinoamérica. React, Next.js, NestJS, TypeScript, Flutter. Ciudad del Este, Paraguay."
  keywords="desarrollador full stack remoto, programador freelance paraguay, react developer latam, nestjs developer, desarrollo web latam, contratar desarrollador remoto, flutter developer, React, NestJS, Node.js, TypeScript, Flutter, PostgreSQL, MongoDB, Docker"
  canonicalUrl="https://mauriciogonzalez.dev/"
  ogType="profile"
  jsonLd={jsonLd}
  pageType="home"
>
  <DarkModeToggle slot="before-header" />
  <HeroSection />
  <AvailabilitySection />
  <AboutSection />
  <SkillsSection />
  <ExperienceSection />
  <EducationSection />
  <ProjectsSection />
  <ServicesSection />
  <BlogPreviewSection />
  <ContactSection />
</BaseLayout>
