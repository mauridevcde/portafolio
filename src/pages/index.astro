---
import BaseLayout from '../layouts/BaseLayout.astro';
import DarkModeToggle from '../components/DarkModeToggle.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import AvailabilitySection from '../components/sections/AvailabilitySection.astro';
import AboutSection from '../components/sections/AboutSection.astro';
import SkillsSection from '../components/sections/SkillsSection.astro';
import ExperienceSection from '../components/sections/ExperienceSection.astro';
import EducationSection from '../components/sections/EducationSection.astro';
import ProjectsSection from '../components/sections/ProjectsSection.astro';
import ServicesSection from '../components/sections/ServicesSection.astro';
import ContactSection from '../components/sections/ContactSection.astro';
import BlogPreviewSection from '../components/sections/BlogPreviewSection.astro';

const jsonLd = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Mauricio González',
    jobTitle: 'Full Stack Developer',
    description: 'Full Stack Developer con 5+ años de experiencia en React, NestJS, Node.js, TypeScript y Flutter. Disponible para posiciones presenciales, híbridas y remotas.',
    url: 'https://mauriciogonzalez.dev',
    image: 'https://mauriciogonzalez.dev/assets/mauriciogonzalezpicture.png',
    email: 'mauridevcde@gmail.com',
    telephone: '+595993510816',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Ciudad del Este',
      addressRegion: 'Alto Paraná',
      addressCountry: 'PY',
    },
    alumniOf: {
      '@type': 'CollegeOrUniversity',
      name: 'Universidad Privada del Este',
    },
    knowsAbout: ['React', 'Next.js', 'NestJS', 'Node.js', 'TypeScript', 'Flutter', 'Dart', 'PostgreSQL', 'MySQL', 'MongoDB', 'Docker'],
    sameAs: ['https://github.com/mauridevcde', 'https://www.linkedin.com/in/ing-mauricio-gonzalez'],
    seeks: { '@type': 'Demand', name: 'Posición Full Stack Developer remoto en Latinoamérica' },
    nationality: 'PY',
    hasOccupation: {
      '@type': 'Occupation',
      name: 'Full Stack Developer',
      description: 'Desarrollo de aplicaciones web y móviles con React, NestJS, TypeScript y Flutter',
    },
    worksFor: {
      '@type': 'Organization',
      name: 'Freelance / Remoto',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: '¿Quién es Mauricio González desarrollador?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Mauricio González es un Full Stack Developer con 5+ años de experiencia en React, Next.js, NestJS, TypeScript, Flutter y PostgreSQL, basado en Ciudad del Este, Paraguay. Disponible para trabajo remoto en Latinoamérica.',
        },
      },
      {
        '@type': 'Question',
        name: '¿Qué tecnologías domina Mauricio González?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'React, Next.js, NestJS, Node.js, TypeScript, Flutter, PostgreSQL, MySQL, Docker, Redis y Firebase.',
        },
      },
      {
        '@type': 'Question',
        name: '¿Está disponible para trabajo remoto?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Sí, Mauricio González está disponible para posiciones remotas, híbridas y presenciales en Latinoamérica.',
        },
      },
      {
        '@type': 'Question',
        name: '¿Cómo contratar a Mauricio González?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Podés contactar a Mauricio González a través del formulario en mauriciogonzalez.dev, por LinkedIn en linkedin.com/in/ing-mauricio-gonzalez o por email en mauridevcde@gmail.com.',
        },
      },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@graph': [
      {
        '@type': 'SoftwareApplication',
        name: 'Sistema de Gestión Veterinaria — Frontend',
        description: 'Aplicación web con Next.js y React. Protección de rutas mediante Next Middleware, gestión de estado con Zustand y autenticación JWT.',
        applicationCategory: 'BusinessApplication',
        operatingSystem: 'Web',
        programmingLanguage: ['TypeScript', 'React', 'Next.js'],
        author: { '@type': 'Person', name: 'Mauricio González', url: 'https://mauriciogonzalez.dev' },
        codeRepository: 'https://github.com/mauridevcde/Front_sis_vet',
      },
      {
        '@type': 'SoftwareApplication',
        name: 'Sistema de Gestión Veterinaria — Backend',
        description: 'API REST con Node.js, Express y TypeScript. Validación de esquemas con Zod, autenticación JWT con control de roles y modelo relacional en MySQL2.',
        applicationCategory: 'BusinessApplication',
        operatingSystem: 'Web',
        programmingLanguage: ['TypeScript', 'Node.js', 'Express'],
        author: { '@type': 'Person', name: 'Mauricio González', url: 'https://mauriciogonzalez.dev' },
        codeRepository: 'https://github.com/mauridevcde/backend_sis_vet',
      },
      {
        '@type': 'BreadcrumbList',
