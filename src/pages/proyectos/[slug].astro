---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { projects } from '../../data/projects';
import ProjectGallery from '../../components/sections/ProjectGallery.astro';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: project.title,
  description: project.description,
  applicationCategory: 'WebApplication',
  operatingSystem: 'Web',
  programmingLanguage: project.tags,
  author: {
    '@type': 'Person',
    name: 'Mauricio González',
    url: 'https://mauriciogonzalez.dev',
  },
});
---

<BaseLayout
  title={`${project.title} — Mauricio González`}
  description={project.description}
  canonicalUrl={`https://mauriciogonzalez.dev/proyectos/${project.slug}/`}
  jsonLd={jsonLd}
  activePage="home"
>
  <section class="section proyecto-detalle">
    <div class="container">

      <a href="/#projects" class="back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        Volver a Proyectos
      </a>

      <div class="proyecto-hero">
        <div class="gradient-bar" style={`background: ${project.gradient}`}></div>
        <div class="hero-content">
          <div class="hero-badges">
            <span class="category-badge">{project.category}</span>
            <span class={`status-chip status-${project.status}`}>
              {project.status === 'live' ? '● Live' : '◌ En desarrollo'}
            </span>
          </div>
          <h1>{project.title}</h1>
          <p class="lead">{project.description}</p>
        </div>
      </div>

      <ProjectGallery images={project.images || []} title={project.title} />

      <div class="proyecto-body">
        <div class="descripcion-card">
          <h2>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
              <polyline points="14 2 14 8 20 8"></polyline>
              <line x1="16" y1="13" x2="8" y2="13"></line>
              <line x1="16" y1="17" x2="8" y2="17"></line>
              <polyline points="10 9 9 9 8 9"></polyline>
            </svg>
            Sobre el proyecto
          </h2>
          <p>{project.longDescription}</p>
        </div>

        <div class="tech-section">
          <h2>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="16 18 22 12 16 6"></polyline>
              <polyline points="8 6 2 12 8 18"></polyline>
            </svg>
            Stack tecnológico
          </h2>
          <div class="tech-tags">
            {project.tags.map((tag) => (
              <span class="tech-tag">
                {tag}
              </span>
            ))}
          </div>
        </div>

        {(project.links.github || project.links.demo) && (
          <div class="links-section">
            <h2>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
                <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
              </svg>
              Enlaces
            </h2>
            <div class="project-links">
              {project.links.github && project.links.github !== '#' && (
                <a
                  href={project.links.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="link-btn github-btn"
                >
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
                  Ver Código
                </a>
              )}
              {project.links.demo && project.links.demo !== '#' && (
                <a
                  href={project.links.demo}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="link-btn demo-btn"
                >
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                  Ver Demo
                </a>
              )}
            </div>
          </div>
        )}
      </div>

    </div>
  </section>
</BaseLayout>

<style>
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    text-decoration: none;
    color: var(--text-light);
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 36px;
    transition: color 0.2s ease;
  }

  .back-link:hover {
    color: var(--primary-color);
  }

  .proyecto-hero {
    border-radius: 16px;
    overflow: hidden;
    background-color: var(--card-bg);
    box-shadow: var(--shadow);
    margin-bottom: 32px;
  }

  .gradient-bar {
    height: 5px;
  }

  .hero-content {
    padding: 36px 40px 40px;
  }

  .hero-badges {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 20px;
  }

  .category-badge {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--primary-color);
    background: rgba(160, 82, 45, 0.1);
    padding: 4px 12px;
    border-radius: 20px;
    border: 1px solid rgba(160, 82, 45, 0.25);
  }

  .status-chip {
    font-size: 0.72rem;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 20px;
  }

  .status-live {
    color: #22c55e;
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.3);
  }

  .status-dev {
    color: var(--text-light);
    background: rgba(100, 100, 100, 0.1);
    border: 1px solid rgba(100, 100, 100, 0.2);
  }

  h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 16px;
    color: var(--text-color);
  }

  .lead {
    font-size: 1.1rem;
    color: var(--text-light);
    line-height: 1.7;
    max-width: 680px;
  }

  .proyecto-body {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .descripcion-card,
  .tech-section,
  .links-section {
    background-color: var(--card-bg);
    border-radius: 16px;
    padding: 32px 40px;
    box-shadow: var(--shadow);
  }

  .descripcion-card h2,
  .tech-section h2,
  .links-section h2 {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--primary-color);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 16px;
  }

  .descripcion-card h2 svg,
  .tech-section h2 svg,
  .links-section h2 svg {
    flex-shrink: 0;
  }

  .descripcion-card p {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--text-light);
  }

  .tech-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .tech-tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--primary-color);
    background: rgba(160, 82, 45, 0.08);
    border: 1px solid rgba(160, 82, 45, 0.22);
    padding: 8px 16px;
    border-radius: 8px;
    transition: background 200ms ease, transform 150ms ease;
  }

  .tech-tag:hover {
    background: rgba(160, 82, 45, 0.15);
    transform: translateY(-2px);
  }

  .project-links {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
  }

  .link-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 22px;
    border-radius: 10px;
    font-size: 0.9rem;
    font-weight: 700;
    text-decoration: none;
    transition: var(--transition);
    cursor: pointer;
  }

  .github-btn {
    background-color: var(--text-color);
    color: var(--bg-color);
  }

  .github-btn:hover {
    background-color: var(--primary-color);
  }

  .demo-btn {
    background-color: var(--primary-color);
    color: #fff;
  }

  .demo-btn:hover {
    background-color: var(--primary-hover);
  }

  @media (max-width: 768px) {
    .hero-content {
      padding: 24px 24px 28px;
    }

    .descripcion-card,
    .tech-section,
    .links-section {
      padding: 24px;
    }
  }
</style>
