---
---

<section id="skills" class="section skills">
  <div class="container">
    <h2 class="section-title reveal">Mis <span>Habilidades</span></h2>
    <div class="skills-grid reveal-stagger">
      <div class="skill-category">
        <h3><i class="fas fa-laptop-code"></i> Frontend</h3>
        <ul>
          <li>React / Next.js</li>
          <li>TypeScript / JavaScript</li>
          <li>TailwindCSS / HTML5 / CSS3</li>
          <li>PrimeReact</li>
        </ul>
      </div>
      <div class="skill-category">
        <h3><i class="fas fa-mobile-alt"></i> Mobile</h3>
        <ul>
          <li>Flutter</li>
          <li>Dart</li>
          <li>FCM (Push Notifications)</li>
          <li>WebSockets</li>
        </ul>
      </div>
      <div class="skill-category">
        <h3><i class="fas fa-server"></i> Backend</h3>
        <ul>
          <li>NestJS</li>
          <li>Node.js / Express.js</li>
          <li>APIs REST · JWT · RBAC</li>
          <li>Zod</li>
        </ul>
      </div>
      <div class="skill-category">
        <h3><i class="fas fa-database"></i> Bases de Datos</h3>
        <ul>
          <li>PostgreSQL</li>
          <li>MySQL</li>
          <li>MongoDB</li>
        </ul>
      </div>
      <div class="skill-category">
        <h3><i class="fas fa-tools"></i> DevOps &amp; Tools</h3>
        <ul>
          <li>Docker</li>
          <li>Git / GitHub / GitLab</li>
          <li>CI/CD</li>
          <li>Jira / Postman</li>
          <li>Scrum / Kanban</li>
        </ul>
      </div>
    </div>
  </div>
</section>
