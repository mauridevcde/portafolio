---
interface Props {
  images: string[];
  title: string;
}

const { images, title } = Astro.props;
---

{images && images.length > 0 && (
  <section class="gallery-section">
    <div class="gallery-hero">
      <img 
        id="gallery-main" 
        src={images[0]} 
        alt={`${title} - Imagen principal`}
        class="main-image"
        loading="eager"
      />
      <button id="gallery-expand" class="expand-btn" aria-label="Expandir imagen" type="button">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 3 21 3 21 9"></polyline>
          <polyline points="9 21 3 21 3 15"></polyline>
          <line x1="21" y1="3" x2="14" y2="10"></line>
          <line x1="3" y1="21" x2="10" y2="14"></line>
        </svg>
        <span>Ver en pantalla completa</span>
      </button>
    </div>

    <div class="thumbnails-grid" role="tablist" aria-label="Galería de imágenes">
      {images.map((img, index) => (
        <button 
          class="thumbnail" 
          class:active={index === 0}
          data-index={index}
          data-src={img}
          aria-label={`Imagen ${index + 1} de ${title}`}
          aria-selected={index === 0}
          role="tab"
          type="button"
        >
          <img src={img} alt="" loading="lazy" />
        </button>
      ))}
    </div>
  </section>
)}

<div id="lightbox" class="lightbox" role="dialog" aria-modal="true" aria-label="Galería de imágenes" hidden>
  <div class="lightbox-backdrop" id="lightbox-backdrop"></div>
  <div class="lightbox-content">
    <img id="lightbox-img" src="" alt="" />
    
    <button id="lightbox-close" class="lightbox-btn close-btn" aria-label="Cerrar galería" type="button">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
    
    <button id="lightbox-prev" class="lightbox-btn nav-btn prev" aria-label="Imagen anterior" type="button">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
    </button>
    
    <button id="lightbox-next" class="lightbox-btn nav-btn next" aria-label="Siguiente imagen" type="button">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </button>

    <div class="lightbox-counter">
      <span id="lightbox-current">1</span> / <span id="lightbox-total">1</span>
    </div>
  </div>
</div>

<script>
  document.addEventListener('astro:page-load', initGallery);
  document.addEventListener('DOMContentLoaded', initGallery);

  function initGallery() {
    const mainImg = document.getElementById('gallery-main') as HTMLImageElement;
    const thumbnails = document.querySelectorAll('.thumbnail');
    const expandBtn = document.getElementById('gallery-expand');
    
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
    const lightboxBackdrop = document.getElementById('lightbox-backdrop');
    const lightboxClose = document.getElementById('lightbox-close');
    const lightboxPrev = document.getElementById('lightbox-prev');
    const lightboxNext = document.getElementById('lightbox-next');
    const lightboxCurrent = document.getElementById('lightbox-current');
    const lightboxTotal = document.getElementById('lightbox-total');

    if (!mainImg || !lightbox || !lightboxImg) return;

    const imageSources = Array.from(thumbnails).map(t => t.getAttribute('data-src') || '');
    let currentIndex = 0;

    function updateMainImage(index: number) {
      currentIndex = index;
      mainImg.src = imageSources[index];
      
      thumbnails.forEach((t, i) => {
        t.classList.toggle('active', i === index);
        (t as HTMLButtonElement).ariaSelected = String(i === index);
      });
    }

    function openLightbox(index: number) {
      currentIndex = index;
      lightboxImg.src = imageSources[index];
      lightbox.removeAttribute('hidden');
      document.body.style.overflow = 'hidden';
      
      if (lightboxCurrent) lightboxCurrent.textContent = String(index + 1);
      if (lightboxTotal) lightboxTotal.textContent = String(imageSources.length);
      
      lightbox.focus();
    }

    function closeLightbox() {
      lightbox.setAttribute('hidden', '');
      document.body.style.overflow = '';
      expandBtn?.focus();
    }

    function navigate(direction: number) {
      let newIndex = currentIndex + direction;
      if (newIndex < 0) newIndex = imageSources.length - 1;
      if (newIndex >= imageSources.length) newIndex = 0;
      
      currentIndex = newIndex;
      lightboxImg.src = imageSources[newIndex];
      if (lightboxCurrent) lightboxCurrent.textContent = String(newIndex + 1);
    }

    // Thumbnail clicks
    thumbnails.forEach((thumb, index) => {
      thumb.addEventListener('click', () => {
        updateMainImage(index);
      });
      
      thumb.addEventListener('dblclick', () => {
        openLightbox(index);
      });
    });

    // Expand button
    expandBtn?.addEventListener('click', () => openLightbox(currentIndex));

    // Lightbox controls
    lightboxClose?.addEventListener('click', closeLightbox);
    lightboxBackdrop?.addEventListener('click', closeLightbox);
    lightboxPrev?.addEventListener('click', () => navigate(-1));
    lightboxNext?.addEventListener('click', () => navigate(1));

    // Keyboard navigation
    document.addEventListener('keydown', (e) => {
      if (lightbox.hasAttribute('hidden')) return;
      
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') navigate(-1);
      if (e.key === 'ArrowRight') navigate(1);
    });

    // Reduced motion
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    if (prefersReducedMotion.matches) {
      document.documentElement.style.setProperty('--gallery-transition', '0ms');
    }
  }
</script>

<style>
  .gallery-section {
    margin-bottom: 32px;
  }

  .gallery-hero {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    background: var(--card-bg);
    box-shadow: var(--shadow);
  }

  .main-image {
    width: 100%;
    height: auto;
    max-height: 500px;
    object-fit: cover;
    display: block;
    transition: opacity var(--gallery-transition, 200ms) ease;
  }

  .expand-btn {
    position: absolute;
    bottom: 16px;
    right: 16px;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 10px;
    color: #fff;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 200ms ease, transform 150ms ease;
  }

  .expand-btn:hover {
    background: rgba(0, 0, 0, 0.85);
    transform: scale(1.03);
  }

  .expand-btn:active {
    transform: scale(0.97);
  }

  .thumbnails-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
    gap: 10px;
    margin-top: 12px;
  }

  .thumbnail {
    aspect-ratio: 16 / 10;
    border-radius: 8px;
    overflow: hidden;
    border: 2px solid transparent;
    background: var(--card-bg);
    padding: 0;
    cursor: pointer;
    transition: border-color 200ms ease, transform 150ms ease, opacity 200ms ease;
    opacity: 0.6;
  }

  .thumbnail:hover {
    opacity: 0.9;
  }

  .thumbnail.active {
    border-color: var(--primary-color);
    opacity: 1;
  }

  .thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Lightbox */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
  }

  .lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.92);
    backdrop-filter: blur(8px);
  }

  .lightbox-content {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px;
  }

  .lightbox-content img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    border-radius: 8px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
  }

  .lightbox-btn {
    position: absolute;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 50%;
    color: #fff;
    cursor: pointer;
    transition: background 200ms ease, transform 150ms ease;
  }

  .lightbox-btn:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  .lightbox-btn:active {
    transform: scale(0.92);
  }

  .close-btn {
    top: 20px;
    right: 20px;
  }

  .nav-btn {
    top: 50%;
    transform: translateY(-50%);
  }

  .nav-btn.prev {
    left: 20px;
  }

  .nav-btn.next {
    right: 20px;
  }

  .lightbox-counter {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(8px);
    padding: 8px 16px;
    border-radius: 20px;
    color: #fff;
    font-size: 0.85rem;
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .main-image {
      max-height: 300px;
    }

    .expand-btn span {
      display: none;
    }

    .expand-btn {
      padding: 12px;
      border-radius: 50%;
    }

    .thumbnails-grid {
      grid-template-columns: repeat(auto-fill, minmax(70px, 1fr));
      gap: 8px;
    }

    .lightbox-content {
      padding: 20px;
    }

    .lightbox-btn {
      width: 40px;
      height: 40px;
    }

    .nav-btn.prev {
      left: 8px;
    }

    .nav-btn.next {
      right: 8px;
    }

    .close-btn {
      top: 12px;
      right: 12px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .main-image,
    .thumbnail,
    .expand-btn,
    .lightbox-btn {
      transition: none;
    }
  }
</style>